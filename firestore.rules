rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      // قراءة عامة حتى يعمل وضع الزائر الموجود في الواجهة.
      allow read: if true;

      // لا كتابة ولا تعديل ولا حذف إلا لمستخدم مسجل دخوله في Firebase Authentication.
      allow create, update, delete: if request.auth != null;
    }
  }
}
